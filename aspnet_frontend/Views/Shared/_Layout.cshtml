@*
    DerivAI — Shared Layout (_Layout.cshtml)
    =========================================
    Master layout using Bootstrap 5.3 with a dark sidebar navigation.
    All pages inherit this layout for consistent UI structure.
    
    Dependencies (loaded via CDN):
    - Bootstrap 5.3.3 (CSS + JS)
    - Bootstrap Icons 1.11
    - Chart.js 4.4 (for dashboard charts)
*@
<!DOCTYPE html>
<html lang="en" class="h-100">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — DerivAI</title>

    <!-- Bootstrap 5.3 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" 
          rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" 
          rel="stylesheet" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="d-flex h-100">

    <!-- ═══ Sidebar Navigation ═══ -->
    <nav id="sidebar" class="d-flex flex-column flex-shrink-0 p-3 text-white bg-dark"
         style="width: 260px; min-height: 100vh;">

        <!-- Brand / Logo -->
        <a href="/" class="d-flex align-items-center mb-3 text-white text-decoration-none border-bottom pb-3">
            <div class="d-flex align-items-center justify-content-center rounded-3 bg-success me-2"
                 style="width: 40px; height: 40px; font-weight: 700; font-size: 18px;">D</div>
            <div>
                <span class="fs-5 fw-bold">DerivAI</span>
                <br />
                <small class="text-secondary" style="font-size: 11px;">Trade Confirmation Intelligence</small>
            </div>
        </a>

        <!-- Navigation Links -->
        <ul class="nav nav-pills flex-column mb-auto">
            <li class="nav-item">
                <a href="@Url.Action("Index", "DerivAI")"
                   class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "DerivAI" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active bg-success" : "")">
                    <i class="bi bi-speedometer2 me-2"></i>
                    Dashboard
                </a>
            </li>

            <li class="nav-item">
                <a href="@Url.Action("AuditTrail", "DerivAI")"
                   class="nav-link text-white @(ViewContext.RouteData.Values["action"]?.ToString() == "AuditTrail" ? "active bg-success" : "")">
                    <i class="bi bi-journal-text me-2"></i>
                    Audit Trail
                </a>
            </li>
            <li class="nav-item mt-3 pt-3 border-top border-secondary">
                <a href="@Url.Action("TestBedrock", "DerivAI")"
                   class="nav-link text-white @(ViewContext.RouteData.Values["action"]?.ToString() == "TestBedrock" ? "active bg-success" : "")">
                    <i class="bi bi-cpu me-2"></i>
                    AI Diagnostics
                </a>
            </li>
        </ul>

        <!-- User Info -->
        <div class="border-top pt-3">
            <div class="d-flex align-items-center text-white">
                <div class="rounded-circle bg-success d-flex align-items-center justify-content-center me-2"
                     style="width: 32px; height: 32px; font-size: 14px; font-weight: 700;">
                    U
                </div>
                <div>
                    <small class="d-block fw-medium">Operations User</small>
                    <small class="text-secondary">Operations Analyst</small>
                </div>
            </div>
        </div>
    </nav>

    <!-- ═══ Main Content Area ═══ -->
    <div class="flex-grow-1 d-flex flex-column" style="min-width: 0;">

        <!-- Top Header Bar -->
        <header class="bg-white border-bottom px-4 py-3 d-flex justify-content-between align-items-center">
            <div>
                <h4 class="mb-0 fw-bold">@ViewData["Title"]</h4>
                @if (ViewData["Subtitle"] != null)
                {
                    <small class="text-muted">@ViewData["Subtitle"]</small>
                }
            </div>
            <div>
                <!-- AI Status Indicator -->
                <span id="ai-status" class="badge rounded-pill bg-secondary-subtle text-secondary border border-secondary-subtle px-3 py-2">
                    <span class="spinner-border spinner-border-sm me-1" style="width: 8px; height: 8px;"></span>
                    Checking...
                </span>
            </div>
        </header>

        <!-- Flash Messages (Success / Error) -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show mx-4 mt-3 mb-0" role="alert">
                <i class="bi bi-check-circle me-1"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null || TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show mx-4 mt-3 mb-0" role="alert">
                <i class="bi bi-exclamation-triangle me-1"></i> @(TempData["ErrorMessage"] ?? TempData["Error"])
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <!-- Page Content -->
        <main class="p-4 flex-grow-1 overflow-auto" style="background-color: #f8f9fa;">
            @RenderBody()
        </main>
    </div>

    <!-- Bootstrap 5.3 JS Bundle (includes Popper.js) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Chart.js for dashboard visualizations -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    
    <!-- AI Engine Status Check -->
    <script>
        async function checkAIStatus() {
            const badge = document.getElementById('ai-status');
            try {
                const response = await fetch('/DerivAI/HealthCheck');
                if (response.ok) {
                    const data = await response.json();
                    
                    if (data.isConnected) {
                        badge.className = 'badge rounded-pill bg-success-subtle text-success border border-success-subtle px-3 py-2';
                        badge.innerHTML = '<span class="spinner-grow spinner-grow-sm me-1" style="width: 8px; height: 8px;"></span>AI Engine Online';
                    } else {
                        badge.className = 'badge rounded-pill bg-danger-subtle text-danger border border-danger-subtle px-3 py-2';
                        badge.innerHTML = '<i class="bi bi-x-circle me-1"></i>AI Engine Offline';
                    }
                } else {
                    badge.className = 'badge rounded-pill bg-danger-subtle text-danger border border-danger-subtle px-3 py-2';
                    badge.innerHTML = '<i class="bi bi-x-circle me-1"></i>AI Engine Offline';
                }
            } catch (error) {
                badge.className = 'badge rounded-pill bg-danger-subtle text-danger border border-danger-subtle px-3 py-2';
                badge.innerHTML = '<i class="bi bi-x-circle me-1"></i>AI Engine Offline';
            }
        }
        
        // Check status on page load
        checkAIStatus();
        // Re-check every 30 seconds
        setInterval(checkAIStatus, 30000);
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
